// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Usuario{
  id Int @id @default(autoincrement())
  nome String 
  email String @unique
  senhaHash String 
  cargo Cargo @default(Estudante)
  dataCriacao DateTime @default(now()) @map("criado_em")
  cursoCriado Curso[]
  matriculas Matricula[]

  @@map("usuarios")
}

model Curso{
  id Int @id @default(autoincrement())
  titulo String
  descricao String
  capa String
  modulo Modulo[]
  matriculas Matricula[]
  instrutorId Usuario @relation(fields: [criadorId],references: [id])
  criadorId Int @map("instrutor_id")

  @@map("cursos")
}

model Modulo{
  id Int @id @default(autoincrement())
  nome String
  curso Curso @relation(fields: [cursoId],references: [id])
  cursoId Int @map("id_curso")
  aulas Aula[]
  
  @@map("modulos")
}

model Aula{
  id Int @id @default(autoincrement())
  titulo String
  url String
  ordem Int
  modulo Modulo @relation(fields: [moduloId],references: [id])
  moduloId Int @map("id_modulo") 

  progresso AlunoProgresso[]
  
  @@map("aulas")
}

model Matricula{
  id Int @id @default(autoincrement())
  alunoInscrito Usuario @relation(fields: [alunoId],references: [id])
  alunoId Int 
  cursoId Int
  curso Curso @relation(references: [id],fields: [cursoId])
  criadoEm DateTime @default(now()) @map("criado_em")

  @@unique([alunoId])
  @@map("matriculas")
}

model AlunoProgresso{
  id Int @id @default(autoincrement())
  alunoId Int
  aulaId Int 
  aula Aula @relation(fields: [aulaId],references: [id])
  concluidoProgresso DateTime @default(now()) @map("concluido_em")


  @@unique([alunoId,aulaId])
}

enum Cargo{
  Estudante
  Instrutor
}